    clear
    echo -e "\033[0;36m"
    echo "  ╔═══════════════════════════════════╗"
    echo "  ║       Remove Editor               ║"
    echo "  ╚═══════════════════════════════════╝"
    echo -e "\033[0m"
    echo ""
    echo -e "  \033[0;32m1)\033[0m VSCode"
    echo -e "  \033[0;32m2)\033[0m Cursor"
    echo -e "  \033[0;32m3)\033[0m Zed"
    echo -e "  \033[0;32m4)\033[0m Neovim"
    echo -e "  \033[0;32m5)\033[0m Helix"
