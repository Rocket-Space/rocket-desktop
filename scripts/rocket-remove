    echo -e "  \033[0;32m2)\033[0m Lutris"
    echo -e "  \033[0;32m3)\033[0m Heroic"
    echo -e "  \033[0;32m4)\033[0m RetroArch"
    echo -e "  \033[0;32m5)\033[0m Minecraft"
    echo -e "  \033[0;32m0)\033[0m Back"
