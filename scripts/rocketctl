#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
KWIN_CONFIG="$HOME/.config/kwinrc"
ROCKET_CONFIG="$HOME/.config/rocket/rocket.conf"
TILING_SCRIPT_ID=""

RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
NC='\033[0m'

print_usage() {
    echo -e "${CYAN}Rocket Desktop Control${NC} v1.0.0"
    echo ""
    echo "Usage: rocketctl <command> [options]"
    echo ""
    echo "Layout commands:"
    echo "  layout              Show current layout"
    echo "  layout set <name>   Set layout (master, dwindle, columns, monocle, float)"
    echo "  layout cycle        Cycle through layouts"
    echo ""
    echo "Window commands:"
    echo "  focus <direction>   Focus window (left, right, up, down)"
    echo "  swap <direction>    Swap window (left, right, up, down)"
    echo "  move <direction>    Move window (left, right, up, down)"
    echo "  float               Toggle floating"
    echo "  fullscreen          Toggle fullscreen"
    echo "  close               Close focused window"
    echo ""
    echo "Master commands:"
    echo "  master grow         Grow master area"
    echo "  master shrink       Shrink master area"
    echo "  master add          Add master window"
    echo "  master remove       Remove master window"
    echo ""
    echo "Workspace commands:"
    echo "  workspace list      List workspaces"
    echo "  workspace next      Next workspace"
    echo "  workspace prev      Previous workspace"
    echo "  workspace create    Create new workspace"
    echo "  workspace remove    Remove last workspace"
    echo ""
    echo "Config commands:"
    echo "  config get <key>    Get config value"
    echo "  config set <key> <value>  Set config value"
    echo "  config reload       Reload configuration"
    echo ""
    echo "Status commands:"
    echo "  status              Show Rocket status"
    echo "  windows             List tiled windows"
    echo ""
    echo "Session commands:"
    echo "  start               Start Rocket session"
    echo "  stop                Stop Rocket session"
    echo "  restart             Restart Rocket session"
}

get_tiling_config() {
    local group="$1"
    local key="$2"
    local default="$3"
    if [ -f "$KWIN_CONFIG" ]; then
        local val=$(grep -A 100 "\[RocketTiling\]" "$KWIN_CONFIG" 2>/dev/null | grep "^${key}=" | head -1 | cut -d= -f2-)
        if [ -n "$val" ]; then
            echo "$val"
        else
            echo "$default"
        fi
    else
        echo "$default"
    fi
}

set_tiling_config() {
    local key="$1"
    local value="$2"
    mkdir -p "$(dirname "$KWIN_CONFIG")"
    if [ ! -f "$KWIN_CONFIG" ]; then
        echo "[RocketTiling]" > "$KWIN_CONFIG"
        echo "${key}=${value}" >> "$KWIN_CONFIG"
    else
        if grep -q "\[RocketTiling\]" "$KWIN_CONFIG"; then
            if grep -A 100 "\[RocketTiling\]" "$KWIN_CONFIG" | grep -q "^${key}="; then
                sed -i "/\[RocketTiling\]/,/^\[/{s/^${key}=.*/${key}=${value}/}" "$KWIN_CONFIG"
            else
                sed -i "/\[RocketTiling\]/a ${key}=${value}" "$KWIN_CONFIG"
            fi
        else
            echo "" >> "$KWIN_CONFIG"
            echo "[RocketTiling]" >> "$KWIN_CONFIG"
            echo "${key}=${value}" >> "$KWIN_CONFIG"
        fi
    fi
}

cmd_layout() {
    case "$1" in
        set)
            case "$2" in
                master|dwindle|columns|monocle|float)
                    set_tiling_config "layout" "$2"
                    echo -e "${GREEN}Layout set to: $2${NC}"
                    qdbus6 org.kde.KWin /Scripting org.kde.kwin.Scripting.reloadScripting 2>/dev/null || true
                    ;;
                *)
                    echo -e "${RED}Invalid layout: $2${NC}"
                    echo "Valid layouts: master, dwindle, columns, monocle, float"
                    exit 1
                    ;;
            esac
            ;;
        cycle)
            qdbus6 org.kde.KWin /KWin org.kde.KWin.cycleLayout 2>/dev/null || \
            echo -e "${YELLOW}Use keyboard shortcut Meta+T to cycle layouts${NC}"
            ;;
        "")
            local current=$(get_tiling_config "RocketTiling" "layout" "master")
            echo -e "Current layout: ${CYAN}${current}${NC}"
            ;;
        *)
            echo -e "${RED}Usage: rocketctl layout [set <name>|cycle]${NC}"
            exit 1
            ;;
    esac
}

cmd_config() {
    case "$1" in
        get)
            if [ -n "$2" ]; then
                local val=$(get_tiling_config "RocketTiling" "$2" "")
                echo -e "${CYAN}$2${NC} = ${val:-<not set>}"
            else
                echo -e "${RED}Usage: rocketctl config get <key>${NC}"
                exit 1
            fi
            ;;
        set)
            if [ -n "$2" ] && [ -n "$3" ]; then
                set_tiling_config "$2" "$3"
                echo -e "${GREEN}$2 = $3${NC}"
            else
                echo -e "${RED}Usage: rocketctl config set <key> <value>${NC}"
                exit 1
            fi
            ;;
        reload)
            echo -e "${CYAN}Reloading KWin configuration...${NC}"
            qdbus6 org.kde.KWin /KWin org.kde.KWin.reconfigure 2>/dev/null || true
            echo -e "${GREEN}Done${NC}"
            ;;
        *)
            echo -e "${RED}Usage: rocketctl config [get|set|reload]${NC}"
            exit 1
            ;;
    esac
}

cmd_status() {
    echo -e "${CYAN}═══════════════════════════════════${NC}"
    echo -e "${CYAN}  Rocket Desktop Environment${NC}"
    echo -e "${CYAN}═══════════════════════════════════${NC}"
    echo ""

    local layout=$(get_tiling_config "RocketTiling" "layout" "master")
    local gap=$(get_tiling_config "RocketTiling" "gap" "8")
    local ratio=$(get_tiling_config "RocketTiling" "masterRatio" "0.55")

    echo -e "  Layout:    ${GREEN}${layout}${NC}"
    echo -e "  Gap:       ${GREEN}${gap}px${NC}"
    echo -e "  Ratio:     ${GREEN}${ratio}${NC}"
    echo ""

    if pgrep -f "rocket-session" > /dev/null 2>&1; then
        echo -e "  Session:   ${GREEN}Running${NC}"
    else
        echo -e "  Session:   ${RED}Not running${NC}"
    fi

    if pgrep -f "kwin_wayland" > /dev/null 2>&1; then
        echo -e "  Compositor:${GREEN} KWin running${NC}"
    else
        echo -e "  Compositor:${RED} KWin not running${NC}"
    fi

    local windows=$(qdbus6 org.kde.KWin /KWin org.kde.KWin.getWindowList 2>/dev/null | wc -l)
    echo -e "  Windows:   ${GREEN}${windows}${NC}"
    echo ""
}

cmd_windows() {
    echo -e "${CYAN}Tiled Windows:${NC}"
    qdbus6 org.kde.KWin /KWin org.kde.KWin.getWindowList 2>/dev/null | while read -r addr; do
        local title=$(qdbus6 org.kde.KWin "$addr" org.kde.kwin.Window.caption 2>/dev/null)
        local class=$(qdbus6 org.kde.KWin "$addr" org.kde.kwin.Window.resourceClass 2>/dev/null)
        if [ -n "$title" ]; then
            echo -e "  ${GREEN}●${NC} ${title} ${YELLOW}(${class})${NC}"
        fi
    done
}

cmd_session() {
    case "$1" in
        start)
            if pgrep -f "rocket-session" > /dev/null 2>&1; then
                echo -e "${YELLOW}Rocket session already running${NC}"
            else
                echo -e "${CYAN}Starting Rocket session...${NC}"
                nohup rocket-session > /dev/null 2>&1 &
                echo -e "${GREEN}Session started${NC}"
            fi
            ;;
        stop)
            echo -e "${CYAN}Stopping Rocket session...${NC}"
            pkill -f "rocket-session-bin" 2>/dev/null || true
            echo -e "${GREEN}Session stopped${NC}"
            ;;
        restart)
            cmd_session stop
            sleep 1
            cmd_session start
            ;;
        *)
            echo -e "${RED}Usage: rocketctl session [start|stop|restart]${NC}"
            exit 1
            ;;
    esac
}

case "$1" in
    layout)     shift; cmd_layout "$@" ;;
    focus)      echo -e "${YELLOW}Use keyboard shortcuts: Meta+Arrow${NC}" ;;
    swap)       echo -e "${YELLOW}Use keyboard shortcuts: Meta+Shift+Arrow${NC}" ;;
    move)       echo -e "${YELLOW}Use keyboard shortcuts: Meta+Ctrl+Arrow${NC}" ;;
    float)      echo -e "${YELLOW}Use keyboard shortcut: Meta+Space${NC}" ;;
    fullscreen) echo -e "${YELLOW}Use keyboard shortcut: Meta+F${NC}" ;;
    close)      echo -e "${YELLOW}Use keyboard shortcut: Meta+Q${NC}" ;;
    master)
        case "$2" in
            grow)   echo -e "${YELLOW}Use keyboard shortcut: Meta+L${NC}" ;;
            shrink) echo -e "${YELLOW}Use keyboard shortcut: Meta+H${NC}" ;;
            add)    echo -e "${YELLOW}Use keyboard shortcut: Meta+I${NC}" ;;
            remove) echo -e "${YELLOW}Use keyboard shortcut: Meta+D${NC}" ;;
            *)      echo -e "${RED}Usage: rocketctl master [grow|shrink|add|remove]${NC}" ;;
        esac
        ;;
    workspace)  shift; cmd_workspace "$@" ;;
    config)     shift; cmd_config "$@" ;;
    status)     cmd_status ;;
    windows)    cmd_windows ;;
    session)    shift; cmd_session "$@" ;;
    start)      cmd_session start ;;
    stop)       cmd_session stop ;;
    restart)    cmd_session restart ;;
    help|-h|--help) print_usage ;;
    "")
        print_usage
        ;;
    *)
        echo -e "${RED}Unknown command: $1${NC}"
        echo "Run 'rocketctl help' for usage"
        exit 1
        ;;
esac
