#!/bin/bash
set -e

# ── Environment ─────────────────────────────────────────────────────────────
export QT_QPA_PLATFORM=wayland
export QT_WAYLAND_DISABLE_WINDOWDECORATION=1
export XDG_CURRENT_DESKTOP=Rocket
export XDG_SESSION_TYPE=wayland
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
export ROCKET_VERSION=1.0.0

ROCKET_BIN="/usr/bin/rocket-session-bin"
ROCKET_LOG="$HOME/.rocket-session.log"
ROCKET_PID_FILE="/tmp/rocket-session.pid"

# ── Menu (only from TTY, no display server) ────────────────────────────────
show_menu() {
    clear
    echo -e "\033[0;36m"
    echo "  ╔═══════════════════════════════════╗"
    echo "  ║       Select Desktop Session      ║"
    echo "  ╚═══════════════════════════════════╝"
    echo -e "\033[0m"
    echo ""
    echo -e "  \033[0;32m1)\033[0m Rocket Desktop    \033[1;33m(tiling, cyberpunk)\033[0m"
    echo -e "  \033[0;32m2)\033[0m KDE Plasma        \033[1;33m(full desktop)\033[0m"
    echo -e "  \033[0;32m3)\033[0m Omarchy           \033[1;33m(hyprland)\033[0m"
    echo -e "  \033[0;32m4)\033[0m Shell"
    echo ""
    echo -ne "  \033[0;36mChoose [1-4]: \033[0m"
    read -r choice

    case "$choice" in
        1) launch_rocket ;;
        2)
            if [ -f /usr/bin/startplasma-wayland ]; then
                exec startplasma-wayland
            elif [ -f /usr/bin/startplasma ]; then
                exec startplasma
            else
                echo "KDE Plasma not found"; sleep 2; show_menu
            fi
            ;;
        3)
            if [ -f "$HOME/.local/share/omarchy/bin/omarchy" ]; then
                exec "$HOME/.local/share/omarchy/bin/omarchy"
            elif command -v Hyprland &>/dev/null; then
                exec Hyprland
            else
                echo "Omarchy not found"; sleep 2; show_menu
            fi
            ;;
        4) echo "Dropping to shell..."; exit 0 ;;
        *) echo "Invalid"; sleep 1; show_menu ;;
    esac
}

# ── Launch Rocket Desktop ──────────────────────────────────────────────────
launch_rocket() {
    cleanup() {
        echo "[$(date)] Rocket: Shutting down..." >> "$ROCKET_LOG"
        [ -f "$ROCKET_PID_FILE" ] && kill "$(cat "$ROCKET_PID_FILE")" 2>/dev/null && rm -f "$ROCKET_PID_FILE"
        kill $(jobs -p) 2>/dev/null; wait 2>/dev/null
    }
    trap cleanup EXIT INT TERM

    echo "[$(date)] Rocket: Starting session..." > "$ROCKET_LOG"

    if [ ! -x "$ROCKET_BIN" ]; then
        echo "Rocket: Binary not found at $ROCKET_BIN" >> "$ROCKET_LOG"
        exit 1
    fi

    # ── Clean conflicting KWin shortcuts ─────────────────────────────────────
    echo "[$(date)] Rocket: Cleaning conflicting shortcuts..." >> "$ROCKET_LOG"
    python3 -c "
import sys
kglobal = '$HOME/.config/kglobalshortcutsrc'
try:
    with open(kglobal) as f:
        lines = f.readlines()
    result = []
    for line in lines:
        line = line.rstrip('\n')
        if line.startswith('[') or line.startswith('_') or '=' not in line:
            result.append(line)
            continue
        if line.startswith('Rocket'):
            result.append(line)
            continue
        key, val = line.split('=', 1)
        parts = val.split(',')
        if len(parts) >= 2 and parts[1] != 'none' and parts[1] != '':
            parts[1] = 'none'
        result.append(key + '=' + ','.join(parts))
    with open(kglobal, 'w') as f:
        f.write('\n'.join(result) + '\n')
    print('Shortcuts cleaned', file=sys.stderr)
except Exception as e:
    print(f'Cleanup error: {e}', file=sys.stderr)
" >> "$ROCKET_LOG" 2>&1

    # Disable KWin built-in effects that intercept shortcuts
    KWINRC="$HOME/.config/kwinrc"
    if ! grep -q "\[Effect-overview\]" "$KWINRC" 2>/dev/null; then
        printf "\n[Effect-overview]\nEnable=false\n" >> "$KWINRC"
    fi
    sed -i '/\[Effect-overview\]/,/^\[/{s/Enable=true/Enable=false/}' "$KWINRC" 2>/dev/null

    # Start KWin
    echo "[$(date)] Rocket: Starting KWin compositor..." >> "$ROCKET_LOG"
    kwin_wayland --no-lockscreen --locale1 --xwayland &
    KWIN_PID=$!
    echo "$KWIN_PID" > "$ROCKET_PID_FILE"

    # Wait for Wayland display
    echo "[$(date)] Rocket: Waiting for Wayland display..." >> "$ROCKET_LOG"
    for i in $(seq 1 30); do
        if [ -e "$XDG_RUNTIME_DIR/wayland-0" ]; then
            export WAYLAND_DISPLAY="wayland-0"
            break
        fi
        sleep 0.2
    done

    if [ -z "$WAYLAND_DISPLAY" ]; then
        echo "[$(date)] Rocket: ERROR - Wayland display not ready" >> "$ROCKET_LOG"
        exit 1
    fi

    echo "[$(date)] Rocket: Wayland display ready: $WAYLAND_DISPLAY" >> "$ROCKET_LOG"

    # Load KWin tiling script
    echo "[$(date)] Rocket: Loading KWin tiling script..." >> "$ROCKET_LOG"
    RETRIES=0
    while [ $RETRIES -lt 20 ]; do
        if qdbus6 org.kde.KWin /KWin org.kde.KWin.isActive 2>/dev/null | grep -qi "true\|yes"; then
            break
        fi
        sleep 0.5
        RETRIES=$((RETRIES + 1))
    done
    qdbus6 org.kde.KWin /KWin org.kde.KWin.reconfigure 2>/dev/null || true
    sleep 2
    SCRIPTS=$(qdbus6 org.kde.KWin /Scripting org.kde.kwin.Scripting.isScriptLoaded "rocket-tiling" 2>/dev/null || echo "unknown")
    echo "[$(date)] Rocket: Tiling script loaded: $SCRIPTS" >> "$ROCKET_LOG"

    # Enable effects
    echo "[$(date)] Rocket: Enabling effects..." >> "$ROCKET_LOG"
    sleep 0.5
    qdbus6 org.kde.KWin /Effects org.kde.KWin.Effects.loadEffect "fade" 2>/dev/null || true
    qdbus6 org.kde.KWin /Effects org.kde.KWin.Effects.loadEffect "glide" 2>/dev/null || true
    qdbus6 org.kde.KWin /Effects org.kde.KWin.Effects.loadEffect "slide" 2>/dev/null || true
    qdbus6 org.kde.KWin /Effects org.kde.KWin.Effects.loadEffect "blur" 2>/dev/null || true

    # Launch components
    echo "[$(date)] Rocket: Starting components..." >> "$ROCKET_LOG"
    /usr/lib/kglobalacceld >> "$ROCKET_LOG" 2>&1 &
    rocket-launcher &
    sleep 1
    krunner --daemon 2>/dev/null &
    $ROCKET_BIN --panel >> "$ROCKET_LOG" 2>&1 &
    $ROCKET_BIN --wallpaper >> "$ROCKET_LOG" 2>&1 &
    $ROCKET_BIN --notifications >> "$ROCKET_LOG" 2>&1 &
    $ROCKET_BIN --power >> "$ROCKET_LOG" 2>&1 &

    echo "[$(date)] Rocket: All components launched" >> "$ROCKET_LOG"
    wait $KWIN_PID
    echo "[$(date)] Rocket: KWin exited" >> "$ROCKET_LOG"
}

# ── Entry point ────────────────────────────────────────────────────────────
# Show menu if running from TTY (no display server)
if [ -z "$DISPLAY" ] && [ -z "$WAYLAND_DISPLAY" ]; then
    show_menu
else
    # Launched from SDDM or already in a session
    launch_rocket
fi
