#!/bin/bash

# ── Auto-detect binary ──────────────────────────────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
BUILD_DIR="$PROJECT_DIR/build"

ROCKET_BIN=""
for candidate in \
    "$BUILD_DIR/src/rocket-session-bin" \
    "/usr/bin/rocket-session-bin" \
    "/usr/local/bin/rocket-session-bin" \
    "$HOME/.local/bin/rocket-session-bin"; do
    if [ -x "$candidate" ]; then
        ROCKET_BIN="$candidate"
        break
    fi
done

if [ -z "$ROCKET_BIN" ] && [ -f "$PROJECT_DIR/CMakeLists.txt" ]; then
    echo "[rocket] Building from source..."
    mkdir -p "$BUILD_DIR" 2>/dev/null
    cmake -S "$PROJECT_DIR" -B "$BUILD_DIR" -DCMAKE_BUILD_TYPE=Release 2>&1 | tail -3
    make -C "$BUILD_DIR" -j"$(nproc)" 2>&1 | tail -3
    if [ -x "$BUILD_DIR/src/rocket-session-bin" ]; then
        ROCKET_BIN="$BUILD_DIR/src/rocket-session-bin"
        echo "[rocket] Build complete: $ROCKET_BIN"
    fi
fi

if [ -z "$ROCKET_BIN" ] && [ -x "$BUILD_DIR/src/rocket-session-bin" ]; then
    ROCKET_BIN="$BUILD_DIR/src/rocket-session-bin"
fi

if [ -z "$ROCKET_BIN" ]; then
    echo "[rocket] ERROR: rocket-session-bin not found."
    exit 1
fi

# ── Environment ─────────────────────────────────────────────────────────────
export QT_QPA_PLATFORM=wayland
export QT_WAYLAND_DISABLE_WINDOWDECORATION=1
export XDG_CURRENT_DESKTOP=Rocket
export XDG_SESSION_TYPE=wayland
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
export ROCKET_VERSION=1.1.0

# Qt theme
export QT_QPA_PLATFORMTHEME=qt6ct
export QT_STYLE_OVERRIDE=kvantum

# XDG directories
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"

# Unbuffer Python output for proper logging
export PYTHONUNBUFFERED=1

ROCKET_LOG="$HOME/.rocket-session.log"
ROCKET_PID_FILE="/tmp/rocket-session.pid"

rotate_log() {
    [ -f "$ROCKET_LOG" ] || return 0
    tail -n 1000 "$ROCKET_LOG" > "$ROCKET_LOG.tmp" 2>/dev/null && mv "$ROCKET_LOG.tmp" "$ROCKET_LOG" 2>/dev/null || true
}

# ── Logging ─────────────────────────────────────────────────────────────────
log() {
    rotate_log
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$ROCKET_LOG"
}

# ── Menu (only from TTY, no display server) ────────────────────────────────
show_menu() {
    clear
    echo -e "\033[0;36m"
    echo "  ╔═══════════════════════════════════╗"
    echo "  ║       Select Desktop Session      ║"
    echo "  ╚═══════════════════════════════════╝"
    echo -e "\033[0m"
    echo ""
    echo -e "  \033[0;32m1)\033[0m Rocket Desktop    \033[1;33m(tiling, cyberpunk)\033[0m"
    echo -e "  \033[0;32m2)\033[0m KDE Plasma        \033[1;33m(full desktop)\033[0m"
    echo -e "  \033[0;32m3)\033[0m Omarchy           \033[1;33m(hyprland)\033[0m"
    echo -e "  \033[0;32m4)\033[0m Shell"
    echo ""
    echo -ne "  \033[0;36mChoose [1-4]: \033[0m"
    read -r choice

    case "$choice" in
        1) launch_rocket ;;
        2)
            if [ -f /usr/bin/startplasma-wayland ]; then
                exec startplasma-wayland
            elif [ -f /usr/bin/startplasma ]; then
                exec startplasma
            else
                echo "KDE Plasma not found"; sleep 2; show_menu
            fi
            ;;
        3)
            if [ -f "$HOME/.local/share/omarchy/bin/omarchy" ]; then
                exec "$HOME/.local/share/omarchy/bin/omarchy"
            elif command -v Hyprland &>/dev/null; then
                exec Hyprland
            else
                echo "Omarchy not found"; sleep 2; show_menu
            fi
            ;;
        4) echo "Dropping to shell..."; exit 0 ;;
        *) echo "Invalid"; sleep 1; show_menu ;;
    esac
}

# ── Launch Rocket Desktop ──────────────────────────────────────────────────
launch_rocket() {
    # Track child PIDs for cleanup
    declare -a CHILD_PIDS=()

    cleanup() {
        log "Shutting down..."
        # Kill all tracked child processes
        for pid in "${CHILD_PIDS[@]}"; do
            kill "$pid" 2>/dev/null || true
        done
        # Also kill by process group if any remain
        kill $(jobs -p) 2>/dev/null || true
        wait 2>/dev/null || true
        [ -f "$ROCKET_PID_FILE" ] && rm -f "$ROCKET_PID_FILE"
    }
    trap cleanup EXIT INT TERM

    log "Starting Rocket Desktop session..."

    if [ ! -x "$ROCKET_BIN" ]; then
        log "ERROR: Binary not found at $ROCKET_BIN"
        exit 1
    fi

    # ── Clean conflicting KWin shortcuts ─────────────────────────────────────
    log "Cleaning conflicting shortcuts..."
    python3 -c "
import sys
kglobal = '$HOME/.config/kglobalshortcutsrc'
try:
    with open(kglobal) as f:
        lines = f.readlines()
    result = []
    for line in lines:
        line = line.rstrip('\n')
        if line.startswith('[') or line.startswith('_') or '=' not in line:
            result.append(line)
            continue
        if line.startswith('Rocket'):
            result.append(line)
            continue
        key, val = line.split('=', 1)
        parts = val.split(',')
        if len(parts) >= 2 and parts[1] != 'none' and parts[1] != '':
            parts[1] = 'none'
        result.append(key + '=' + ','.join(parts))
    with open(kglobal, 'w') as f:
        f.write('\n'.join(result) + '\n')
    print('Shortcuts cleaned', file=sys.stderr)
except Exception as e:
    print(f'Cleanup error: {e}', file=sys.stderr)
" >> "$ROCKET_LOG" 2>&1 || true

    KWINRC="$HOME/.config/kwinrc"
    if ! grep -q "\[Effect-overview\]" "$KWINRC" 2>/dev/null; then
        printf "\n[Effect-overview]\nEnable=false\n" >> "$KWINRC" 2>/dev/null || true
    fi
    sed -i '/\[Effect-overview\]/,/^\[/{s/Enable=true/Enable=false/}' "$KWINRC" 2>/dev/null || true

    log "Starting KWin compositor..."
    KWIN_ARGS="--no-lockscreen --xwayland --locale1"
    kwin_wayland $KWIN_ARGS &
    KWIN_PID=$!
    CHILD_PIDS+=("$KWIN_PID")
    echo "$KWIN_PID" > "$ROCKET_PID_FILE"

    log "Waiting for Wayland display..."
    unset WAYLAND_DISPLAY
    for i in $(seq 1 30); do
        if [ -e "$XDG_RUNTIME_DIR/wayland-0" ]; then
            export WAYLAND_DISPLAY="wayland-0"
            break
        fi
        sleep 0.2
    done

    if [ -z "$WAYLAND_DISPLAY" ]; then
        log "ERROR: Wayland display not ready"
        exit 1
    fi

    log "Wayland display ready: $WAYLAND_DISPLAY"

    log "Loading KWin tiling script..."
    RETRIES=0
    while [ $RETRIES -lt 20 ]; do
        if qdbus6 org.kde.KWin /KWin org.kde.KWin.isActive 2>/dev/null | grep -qi "true\|yes"; then
            break
        fi
        sleep 0.5
        RETRIES=$((RETRIES + 1))
    done
    qdbus6 org.kde.KWin /KWin org.kde.KWin.reconfigure 2>/dev/null || true
    sleep 2
    SCRIPTS=$(qdbus6 org.kde.KWin /Scripting org.kde.kwin.Scripting.isScriptLoaded "rocket-tiling" 2>/dev/null || echo "unknown")
    log "Tiling script loaded: $SCRIPTS"

    log "Enabling effects..."
    sleep 0.5
    qdbus6 org.kde.KWin /Effects org.kde.KWin.Effects.loadEffect "fade" 2>/dev/null || true
    qdbus6 org.kde.KWin /Effects org.kde.KWin.Effects.loadEffect "glide" 2>/dev/null || true
    qdbus6 org.kde.KWin /Effects org.kde.KWin.Effects.loadEffect "slide" 2>/dev/null || true
    qdbus6 org.kde.KWin /Effects org.kde.KWin.Effects.loadEffect "blur" 2>/dev/null || true

    log "Starting components..."
    
    COMPONENT_ENV="QT_QPA_PLATFORM=wayland WAYLAND_DISPLAY=wayland-0 XDG_RUNTIME_DIR=$XDG_RUNTIME_DIR"
    
    if [ -x /usr/lib/org_kde_plasma_kglobalacceld ]; then
        env $COMPONENT_ENV /usr/lib/org_kde_plasma_kglobalacceld >> "$ROCKET_LOG" 2>&1 &
        CHILD_PIDS+=("$!")
    elif [ -x /usr/lib/kglobalacceld ]; then
        env $COMPONENT_ENV /usr/lib/kglobalacceld >> "$ROCKET_LOG" 2>&1 &
        CHILD_PIDS+=("$!")
    fi
    
    env $COMPONENT_ENV rocket-launcher &
    CHILD_PIDS+=("$!")
    sleep 1
    
    env $COMPONENT_ENV krunner --daemon 2>/dev/null &
    CHILD_PIDS+=("$!")
    
    env $COMPONENT_ENV $ROCKET_BIN --panel >> "$ROCKET_LOG" 2>&1 &
    CHILD_PIDS+=("$!")
    env $COMPONENT_ENV $ROCKET_BIN --wallpaper >> "$ROCKET_LOG" 2>&1 &
    CHILD_PIDS+=("$!")
    env $COMPONENT_ENV $ROCKET_BIN --notifications >> "$ROCKET_LOG" 2>&1 &
    CHILD_PIDS+=("$!")
    env $COMPONENT_ENV $ROCKET_BIN --power >> "$ROCKET_LOG" 2>&1 &
    CHILD_PIDS+=("$!")
    
    env $COMPONENT_ENV rocket-shortcuts >> "$ROCKET_LOG" 2>&1 &
    CHILD_PIDS+=("$!")

    log "All components launched"
    wait $KWIN_PID
    log "KWin exited"
}

# ── Entry point ────────────────────────────────────────────────────────────
AUTO_LAUNCH=false
for arg in "$@"; do
    case "$arg" in
        --auto|--launch) AUTO_LAUNCH=true ;;
    esac
done

if [ "$AUTO_LAUNCH" = true ]; then
    launch_rocket
elif [ -n "$WAYLAND_DISPLAY" ] || [ -n "$DISPLAY" ]; then
    launch_rocket
else
    show_menu
fi