    echo -e "  \033[0;32m2)\033[0m Chromium"
    echo -e "  \033[0;32m3)\033[0m Brave"
    echo -e "  \033[0;32m4)\033[0m Zen Browser"
    echo -e "  \033[0;32m5)\033[0m Vivaldi"
    echo -e "  \033[0;32m0)\033[0m Back"
    echo ""
    echo -ne "  \033[0;36mChoose [0-5]: \033[0m"
    read -r choice

    case "$choice" in
        1) present_terminal "sudo pacman -S --needed firefox && echo 'Firefox installed!' || echo 'Failed'" ;;
        2) present_terminal "sudo pacman -S --needed chromium && echo 'Chromium installed!' || echo 'Failed'" ;;
        3) present_terminal "yay -S --needed brave-bin && echo 'Brave installed!' || echo 'Failed'" ;;
        4) present_terminal "yay -S --needed zen-browser-bin && echo 'Zen installed!' || echo 'Failed'" ;;
        5) present_terminal "yay -S --needed vivaldi && echo 'Vivaldi installed!' || echo 'Failed'" ;;
        0) back_to show_main_menu ;;
        *) show_browser_menu ;;
    esac
    back_to show_main_menu
}

