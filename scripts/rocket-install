show_service_menu() {
    clear
    echo -e "\033[0;36m"
    echo "  ╔═══════════════════════════════════╗"
    echo "  ║       Install Services            ║"
    echo "  ╚═══════════════════════════════════╝"
    echo -e "\033[0m"
    echo ""
    echo -e "  \033[0;32m1)\033[0m Tailscale (VPN)"
    echo -e "  \033[0;32m2)\033[0m Docker"
    echo -e "  \033[0;32m3)\033[0m Bluetooth"
    echo -e "  \033[0;32m4)\033[0m SSH Server"
    echo -e "  \033[0;32m5)\033[0m Apache/Nginx"
    echo -e "  \033[0;32m0)\033[0m Back"
    echo ""
    echo -ne "  \033[0;36mChoose [0-5]: \033[0m"
    read -r choice

    case "$choice" in
        1) present_terminal "sudo pacman -S --needed tailscale && sudo systemctl enable --now tailscaled && echo 'Tailscale installed!' || echo 'Failed'" ;;
        2) present_terminal "sudo pacman -S --needed docker && sudo systemctl enable --now docker && echo 'Docker installed!' || echo 'Failed'" ;;
        3) present_terminal "sudo pacman -S --needed bluez bluez-utils && sudo systemctl enable --now bluetooth && echo 'Bluetooth installed!' || echo 'Failed'" ;;
        4) present_terminal "sudo pacman -S --needed openssh && sudo systemctl enable --now sshd && echo 'SSH installed!' || echo 'Failed'" ;;
        5) present_terminal "sudo pacman -S --needed nginx && sudo systemctl enable --now nginx && echo 'Nginx installed!' || echo 'Failed'" ;;
        0) back_to show_main_menu ;;
        *) show_service_menu ;;
    esac
    back_to show_main_menu
}

show_windows_menu() {
    clear
    echo -e "\033[0;36m"
    echo "  ╔═══════════════════════════════════╗"
    echo "  ║       Install Windows Tools       ║"
    echo "  ╚═══════════════════════════════════╝"
    echo -e "\033[0m"
    echo ""
    echo -e "  \033[0;32m1)\033[0m Wine"
    echo -e "  \033[0;32m2)\033[0m Proton GE"
    echo -e "  \033[0;32m3)\033[0m Bottles"
    echo -e "  \033[0;32m4)\033[0m QEMU/KVM"
    echo -e "  \033[0;32m5)\033[0m VirtualBox"
    echo -e "  \033[0;32m0)\033[0m Back"
    echo ""
    echo -ne "  \033[0;36mChoose [0-5]: \033[0m"
    read -r choice

    case "$choice" in
        1) present_terminal "sudo pacman -S --needed wine && echo 'Wine installed!' || echo 'Failed'" ;;
        2) present_terminal "yay -S --needed proton-ge-custom-bin && echo 'Proton GE installed!' || echo 'Failed'" ;;
        3) present_terminal "yay -S --needed bottles && echo 'Bottles installed!' || echo 'Failed'" ;;
        4) present_terminal "sudo pacman -S --needed qemu-full virt-manager && echo 'QEMU/KVM installed!' || echo 'Failed'" ;;
        5) present_terminal "sudo pacman -S --needed virtualbox && echo 'VirtualBox installed!' || echo 'Failed'" ;;
        0) back_to show_main_menu ;;
        *) show_windows_menu ;;
    esac
    back_to show_main_menu
}

# Entry point
if [[ "$1" == "--direct" ]]; then
    BACK_TO_EXIT=true
    shift
    case "${1:-}" in
        package) show_package_menu ;;
        browser) show_browser_menu ;;
        editor) show_editor_menu ;;
        terminal) show_terminal_menu ;;
        gaming) show_gaming_menu ;;
        development) show_development_menu ;;
        ai) show_ai_menu ;;
        font) show_font_menu ;;
        style) show_style_menu ;;
        tui) show_tui_menu ;;
        service) show_service_menu ;;
        windows) show_windows_menu ;;
        *) show_main_menu ;;
    esac
else
    show_main_menu
fi
