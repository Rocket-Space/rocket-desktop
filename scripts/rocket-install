#!/bin/bash
# rocket-install - App installer for Rocket Desktop

BACK_TO_EXIT=false

pkg_install() {
    local pkg="$1"
    if ! pacman -Q "$pkg" &>/dev/null; then
        echo "Installing $pkg..."
        sudo pacman -S --noconfirm --needed "$pkg"
    else
        echo "$pkg is already installed"
    fi
}

aur_install() {
    local pkg="$1"
    if ! pacman -Q "$pkg" &>/dev/null; then
        echo "Installing $pkg from AUR..."
        yay -S --noconfirm --needed "$pkg"
    else
        echo "$pkg is already installed"
    fi
}

present_terminal() {
    kitty -e bash -c "$1" 2>/dev/null || alacritty -e bash -c "$1" 2>/dev/null || foot bash -c "$1" 2>/dev/null || xdg-terminal-exec -- bash -c "$1" 2>/dev/null
}

back_to() {
    local parent_menu="$1"
    if [[ $BACK_TO_EXIT == "true" ]]; then
        exit 0
    elif [[ -n $parent_menu ]]; then
        "$parent_menu"
    else
        show_main_menu
    fi
}

show_main_menu() {
    clear
    echo -e "\033[0;36m"
    echo "  ╔═══════════════════════════════════╗"
    echo "  ║       Install Applications        ║"
    echo "  ╚═══════════════════════════════════╝"
    echo -e "\033[0m"
    echo ""
    echo -e "  \033[0;32m1)\033[0m  📦 Package     \033[0;37m- Install any package\033[0m"
    echo -e "  \033[0;32m2)\033[0m  🌐 Browser      \033[0;37m- Web browsers\033[0m"
    echo -e "  \033[0;32m3)\033[0m  ✏️  Editor       \033[0;37m- Code editors\033[0m"
    echo -e "  \033[0;32m4)\033[0m  💻 Terminal     \033[0;37m- Terminal emulators\033[0m"
    echo -e "  \033[0;32m5)\033[0m  🎮 Gaming       \033[0;37m- Games & gaming tools\033[0m"
    echo -e "  \033[0;32m6)\033[0m  🔧 Development  \033[0;37m- Programming tools\033[0m"
    echo -e "  \033[0;32m7)\033[0m  🤖 AI           \033[0;37m- AI tools\033[0m"
    echo -e "  \033[0;32m8)\033[0m  🔤 Font         \033[0;37m- Fonts\033[0m"
    echo -e "  \033[0;32m9)\033[0m  🎨 Style        \033[0;37m- Themes & styles\033[0m"
    echo -e "  \033[0;32m10)\033[0m 📱 TUI          \033[0;37m- Terminal UI apps\033[0m"
    echo -e "  \033[0;32m11)\033[0m 🔌 Service      \033[0;37m- System services\033[0m"
    echo -e "  \033[0;32m12)\033[0m 🪟 Windows      \033[0;37m- Wine/VM/compatibility\033[0m"
    echo -e "  \033[0;32m0)\033[0m  Back"
    echo ""
    echo -ne "  \033[0;36mChoose [0-12]: \033[0m"
    read -r choice

    case "$choice" in
        1) show_package_menu ;;
        2) show_browser_menu ;;
        3) show_editor_menu ;;
        4) show_terminal_menu ;;
        5) show_gaming_menu ;;
        6) show_development_menu ;;
        7) show_ai_menu ;;
        8) show_font_menu ;;
        9) show_style_menu ;;
        10) show_tui_menu ;;
        11) show_service_menu ;;
        12) show_windows_menu ;;
        0) return ;;
        *) show_main_menu ;;
    esac
}

show_package_menu() {
    clear
    echo -e "\033[0;36m"
    echo "  ╔═══════════════════════════════════╗"
    echo "  ║       Install Package             ║"
    echo "  ╚═══════════════════════════════════╝"
    echo -e "\033[0m"
    echo ""
    echo -ne "  \033[0;36mEnter package name: \033[0m"
    read -r pkg
    if [ -n "$pkg" ]; then
        present_terminal "sudo pacman -S --needed $pkg"
    fi
    back_to show_main_menu
}

show_browser_menu() {
    clear
    echo -e "\033[0;36m"
    echo "  ╔═══════════════════════════════════╗"
    echo "  ║       Install Browser             ║"
    echo "  ╚═══════════════════════════════════╝"
    echo -e "\033[0m"
